#!/usr/bin/env bash
# removes sync from .dotfiles
DOTFILES="$HOME/.dotfiles"
unsync_package() {

    local source
    read -rp "Ruta de origen (relativa a \$DOTFILES): " source

    if [[ ! -d "$DOTFILES/$source" ]]; then
        echo "La carpeta '$source' no existe."
        return 1
    fi

    rsync -aAXv "$DOTFILES/${source}/" "$HOME/"
}

unsync_package
